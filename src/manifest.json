{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "browser_specific_settings": {
    "gecko": {
      "id": "lookout@refactored",
      "strict_min_version": "140.0"
    }
  },
  "applications": {
    "gecko": {
      "id": "lookout@refactored",
      "strict_min_version": "140.0"
    }
  },
  "version": "8.0",
  "default_locale": "en-US",
  "author": "sync667",
  "homepage_url": "https://github.com/sync667/LookOut-Refactored/",
  "icons": {
    "32": "icons/LOicon-32.png",
    "48": "icons/LOicon-48.png",
    "64": "icons/LOicon-64.png"
  },
  "experiment_apis": {
    "Attachment": {
      "schema": "api/Attachment/schema.json",
      "parent": {
        "scopes": [
          "addon_parent"
        ],
        "paths": [
          [
            "Attachment"
          ]
        ],
        "script": "api/Attachment/implementation.js"
      }
    }
  },
  "background": {
    "page": "background.html"
  },
  "permissions": [
    "messagesRead",
    "storage"
  ],
  "options_ui": {
    "page": "options/options.html"
  }
}
