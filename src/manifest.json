{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "browser_specific_settings": {
    "gecko": {
      "id": "lookout@refactored",
      "strict_min_version": "140.0",
      "strict_max_version": "152.*",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "version": "1.0.0",
  "default_locale": "en_US",
  "author": "sync667",
  "homepage_url": "https://github.com/sync667/LookOut-Refactored/",
  "icons": {
    "16": "icons/LOicon-16.png",
    "32": "icons/LOicon-32.png",
    "48": "icons/LOicon-48.png",
    "64": "icons/LOicon-64.png",
    "96": "icons/LOicon-96.png",
    "128": "icons/LOicon-128.png"
  },
  "experiment_apis": {
    "Attachment": {
      "schema": "api/Attachment/schema.json",
      "parent": {
        "scopes": [
          "addon_parent"
        ],
        "paths": [
          [
            "Attachment"
          ]
        ],
        "script": "api/Attachment/implementation.js"
      }
    }
  },
  "background": {
    "page": "background.html"
  },
  "permissions": [
    "messagesRead",
    "storage"
  ],
  "options_ui": {
    "page": "options/options.html"
  }
}
